# =============================================================================
# YNAB Financial Report — Environment Configuration
# =============================================================================
#
# This file is OPTIONAL. The .env file is only needed if you want to change
# the default port. All other configuration — including the sync schedule —
# is managed through the browser Settings page.
#
# All security-sensitive configuration (master password, API keys, etc.) is
# handled entirely through the browser UI — no command-line setup required.
#
# INSTRUCTIONS (if you want to customize settings):
#   1. Copy this file to .env:
#        cp .env.example .env
#
#   2. Uncomment and edit any values you want to change.
#
#   3. Start the app:
#        docker-compose up -d
#
#   4. Open http://localhost:8080 — the setup wizard will guide you through
#      creating your master password and configuring the app.
#
# =============================================================================
# !! Do not add API keys or passwords to this file.              !!
# !! All secrets are entered through the browser Settings page.  !!
# =============================================================================


# -----------------------------------------------------------------------------
# OPTIONAL — Server Configuration
# -----------------------------------------------------------------------------

# Port the app listens on (host side). Default: 8080
# Change this if port 8080 is already in use on your machine.
#
# PORT=8080
